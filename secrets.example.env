# ============================================================================
# Copy to secrets.env (gitignored), fill in, then: chmod 600 secrets.env
# run.sh sources this file. If a value is left blank and is needed, run.sh
# prompts for it interactively (no echo). Never commit secrets.env.
# ============================================================================

# Registry admin password - required only when registry.auth: true in input.yaml.
# Must be strong and non-default (preflight rejects known defaults / <8 chars).
REGISTRY_ADMIN_PASSWORD=""

# Optional passphrase to encrypt the self-signed root CA private key.
# Leave blank for an unencrypted CA key.
CA_KEY_PASSPHRASE=""

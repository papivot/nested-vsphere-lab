#!/usr/sbin/nft -f
# Managed by nested-vsphere-lab (routing).
# Egress is ONLY via the public NIC; private VLANs route between each other and
# are NAT'd outbound. Unsolicited inbound from public into private is dropped.
flush ruleset

define PUBLIC = "{{ jumpbox.public_nic }}"
define PRIV_IFACES = { {{ vlans_computed | map(attribute='iface') | unique | join(', ') }} }

table inet filter {
    chain input {
        type filter hook input priority 0; policy accept;
    }

    chain forward {
        type filter hook forward priority 0; policy drop;
        ct state established,related accept
        # private -> anywhere (inter-VLAN + egress)
        iifname $PRIV_IFACES accept
        # block unsolicited inbound from public into the private fabric
        oifname $PRIV_IFACES ct state new drop
    }

    chain output {
        type filter hook output priority 0; policy accept;
    }
}

table ip nat {
    chain postrouting {
        type nat hook postrouting priority srcnat; policy accept;
{% if routing.nat | bool %}
        oifname $PUBLIC masquerade
{% endif %}
    }
}

; Managed by nested-vsphere-lab (dns_bind). Forward zone for {{ jumpbox.domain }}.
$TTL 3600
@   IN  SOA {{ jumpbox.hostname }}.{{ jumpbox.domain }}. admin.{{ jumpbox.domain }}. (
            {{ zone_serial }} ; serial
            3600       ; refresh
            600        ; retry
            604800     ; expire
            3600 )     ; minimum
@           IN  NS  {{ jumpbox.hostname }}.{{ jumpbox.domain }}.
{{ jumpbox.hostname }}  IN  A  {{ vlans_computed | selectattr('is_native') | map(attribute='gateway') | first }}
; VLAN gateway interfaces owned by the jumpbox
{% for v in vlans_computed %}
gw-{{ v.name }}  IN  A  {{ v.gateway }}
{% endfor %}
; Pre-created records for nested nodes (Stage 2)
{% for r in dns.records | default([]) %}
{{ r.name }}  IN  A  {{ r.ip }}
{% endfor %}

# Managed by nested-vsphere-lab (base_os). Upstream HTTP proxy.
{% if proxy.http | default('') | length > 0 %}
export http_proxy="{{ proxy.http }}"
export HTTP_PROXY="{{ proxy.http }}"
{% endif %}
{% if proxy.https | default('') | length > 0 %}
export https_proxy="{{ proxy.https }}"
export HTTPS_PROXY="{{ proxy.https }}"
{% endif %}
export no_proxy="{{ proxy.no_proxy | default('localhost,127.0.0.1') }}"
export NO_PROXY="{{ proxy.no_proxy | default('localhost,127.0.0.1') }}"

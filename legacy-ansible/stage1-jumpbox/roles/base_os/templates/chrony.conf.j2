# Managed by nested-vsphere-lab (base_os).
# The jumpbox is an NTP CLIENT only. Nested nodes reach these upstreams through
# the jumpbox NAT and are pointed here via DHCP option 42 (see dhcp_kea role).
{% for s in ntp.upstream %}
server {{ s }} iburst
{% endfor %}

driftfile /var/lib/chrony/drift
makestep 1.0 3
rtcsync
logdir /var/log/chrony
